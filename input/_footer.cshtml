<footer class="site-footer">
  <div class="container">
    @if (Document.ContainsKey("Canonical"))
    {
      <p class="text-muted">Originally published at <a href='@Document.GetString("Canonical")'>@Document.GetString("Canonical")</a>.</p>
    }
    @Html.Partial("_copyright")
    <ul class="feed-links">
      @{
        IDocument rssFeed = Outputs["**/*.rss"].FirstOrDefault();
        IDocument atomFeed = Outputs["**/*.atom"].FirstOrDefault();
      }
      @if (rssFeed != null) {
        <li>
          <a href="@Context.GetLink(rssFeed)">RSS Feed</a>
        </li>
      }
      @if (atomFeed != null) {
        <li>
          <a href="@Context.GetLink(atomFeed)">Atom Feed</a>
        </li>
      }
    </ul>
    <p class="generated-by"><a href="https://statiq.dev">Generated by Statiq</a></p>
  </div>
</footer>
